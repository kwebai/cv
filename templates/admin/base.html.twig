{% extends 'base.html.twig' %}

{% block body %}

<div class="d-flex">

    <!-- Sidebar -->
    <div class="bg-dark text-white p-3" style="width: 250px; min-height: 100vh;">
        <h4 class="mb-4">Admin Panel</h4>

        <ul class="nav flex-column">

            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'admin_projects' ? 'active' }}"
                href="{{ path('admin_projects') }}">
                    Projects
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'admin_experience' ? 'active' }}" href="{{ path('admin_experience') }}">
                    Experience
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'admin_education' ? 'active' }}" href="{{ path('admin_education') }}">
                    Education
                </a>
            </li>
    
            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'admin_skill' ? 'active' }}" href="{{ path('admin_skill') }}">
                    Skills
                </a>
            </li>
            
            <li class="nav-item">
                <a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'admin_language' ? 'active' }}" href="{{ path('admin_language') }}">
                    Languages
                </a>
            </li>

            <li class="nav-item mt-4">
                <a class="nav-link text-danger" href="{{ path('app_home') }}">
                    <i class="bi bi-arrow-return-left"></i> Back home
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-danger" href="{{ path('admin_logout') }}">
                    <i class="bi bi-power"></i> Logout
                </a>
            </li>

        </ul>
    </div>

    <!-- Content -->
    <div class="flex-fill p-5 bg-light">
        {% block admin_content %}{% endblock %}
    </div>

</div>

{% endblock %}


{% block javascripts %}

{{ parent() }}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<script>

document.addEventListener("DOMContentLoaded", function() {

    document.querySelectorAll('textarea.wysiwyg').forEach(function(textarea){

        let editor = document.createElement('div');
        editor.innerHTML = textarea.value;

        textarea.style.display = "none";
        textarea.parentNode.insertBefore(editor, textarea);

        let quill = new Quill(editor, {
            theme: 'snow',
            modules: {
                toolbar: [
                    ['bold','italic','underline'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        textarea.form.addEventListener('submit', function() {
            textarea.value = quill.root.innerHTML;
        });
    });
});

document.addEventListener("DOMContentLoaded", function () {

    document.querySelectorAll(".sortable").forEach(function (container) {

        new Sortable(container, {
            animation: 150,

            onEnd: function () {

                let order = [];

                container.querySelectorAll("[data-id]").forEach((row, index) => {

                    order.push({
                        id: row.dataset.id,
                        position: index
                    });

                });

                fetch(container.dataset.url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(order)
                });
            }
        });
    });
});

</script>

{% endblock %}