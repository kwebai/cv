{% extends 'admin/base.html.twig' %}

{% block title %}Admin | Skills{% endblock %}

{% block admin_content %}


<h1 class="mb-4">Skills</h1>

<a href="{{ path('admin_skill_new') }}" class="btn btn-primary mb-4">
Add skill
</a>


<table class="table table-striped">

      <thead>

      <tr>
            <th style="width:40px"></th>
            <th>Name</th>
            <th></th>
      </tr>

      </thead>

      <tbody class="sortable" data-url="/admin/skills/reorder">

      {% for ski in skill %}

            <tr data-id="{{ ski.id }}">
                  
                  <td class="drag-handle">☰</td>
                  <td>{{ ski.name }}</td>
                  <td class="text-end">

                        <a href="{{ path('admin_skill_edit', {id: ski.id}) }}"
                        class="btn btn-sm btn-warning">
                        Edit
                        </a>

                        <form method="post"
                              action="{{ path('admin_skill_delete', {id: ski.id}) }}"
                              style="display:inline">

                              <input type="hidden"
                              name="_token"
                              value="{{ csrf_token('delete' ~ ski.id) }}">

                              <button class="btn btn-sm btn-danger">
                              Delete
                              </button>
                        </form>

                  </td>

            </tr>

      {% else %}

            <tr>

            <td colspan="4">
            No skill yet.
            </td>

            </tr>

      {% endfor %}

      </tbody>

</table>

{% endblock %}