{% extends 'admin/base.html.twig' %}

{% block title %}Admin | Languages{% endblock %}

{% block admin_content %}


<h1 class="mb-4">Languages</h1>

<a href="{{ path('admin_language_new') }}" class="btn btn-primary mb-4">
Add Language
</a>


<table class="table table-striped">

      <thead>

      <tr>
            <th style="width:40px"></th>
            <th>Name</th>
            <th></th>
      </tr>

      </thead>

      <tbody class="sortable" data-url="/admin/language/reorder">

      {% for lan in language %}

            <tr data-id="{{ lan.id }}">
                  <td class="drag-handle"><i class="bi bi-grip-vertical"></i></td>
                  <td>{{ lan.name }}</td>

                  <td class="text-end">

                        <a href="{{ path('admin_language_edit', {id: lan.id}) }}"
                        class="btn btn-sm btn-warning">
                        Edit
                        </a>

                        <form method="post"
                              action="{{ path('admin_language_delete', {id: lan.id}) }}"
                              style="display:inline">

                              <input type="hidden"
                              name="_token"
                              value="{{ csrf_token('delete' ~ lan.id) }}">

                              <button class="btn btn-sm btn-danger">
                              Delete
                              </button>
                        </form>

                  </td>

            </tr>

      {% else %}

            <tr>

            <td colspan="4">
            No language yet.
            </td>

            </tr>

      {% endfor %}

      </tbody>

</table>

{% endblock %}