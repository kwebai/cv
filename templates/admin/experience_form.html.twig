{% extends 'admin/base.html.twig' %}

{% block admin_content %}

<section class="py-5 bg-light">
    <div class="container px-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow rounded-4 border-0">
                    <div class="card-body p-5">

                        {{ form_start(form) }}

                            <div class="mb-3">
                                {{ form_label(form.position) }}
                                {{ form_widget(form.position, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.position) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.companyName) }}
                                {{ form_widget(form.companyName, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.companyName) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.companyCity) }}
                                {{ form_widget(form.companyCity, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.companyCity) }}
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.startDate) }}
                                    {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.startDate) }}
                                </div>

                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.endDate) }}
                                    {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.endDate) }}
                                </div>
                            </div>

                            <div class="mb-3 form-check">
                                {{ form_widget(form.current, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(form.current, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                {{ form_errors(form.current) }}
                            </div>

                            <div class="mb-4">
                                {{ form_label(form.description) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control wysiwyg', 'rows': 5}}) }}
                                {{ form_errors(form.description) }}
                            </div>

                            <div class="row">
                                <div class="col-sm-6">
                                    <a href="{{ path('admin_experience') }}" class="btn btn-default">
                                        ← Volver
                                    </a>
                                </div>
                                <div class="col-sm-6 text-end">
                                    <button class="btn btn-primary">
                                        Guardar
                                    </button>
                                </div>
                            </div>

                        {{ form_end(form) }}

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

{% endblock %}